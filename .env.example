# SynapseChat Development Environment Variables
# Copy this to .env and fill in production values

# ─── PostgreSQL ───
POSTGRES_PASSWORD=synapsechat_dev_password

# ─── MinIO (S3-compatible media storage) ───
MINIO_ROOT_USER=synapsechat
MINIO_ROOT_PASSWORD=synapsechat_dev_password

# ─── LiveKit (Voice/Video) ───
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ─── Grafana ───
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=synapsechat_dev

# ─── FCM (Android Push Notifications) ───
# Get these from Firebase Console → Project Settings → Cloud Messaging
FCM_PROJECT_ID=synapsechat-dev
FCM_SERVICE_ACCOUNT_FILE=./infra/sygnal/fcm-service-account.json

# ─── APNs (iOS Push Notifications) ───
# Get these from Apple Developer Console → Certificates, Identifiers & Profiles
APNS_KEY_ID=CHANGE_ME
APNS_TEAM_ID=CHANGE_ME
APNS_TOPIC=org.synapsechat.ios

# ─── Synapse ───
SYNAPSE_SERVER_NAME=synapse.chat
SYNAPSE_PUBLIC_BASEURL=https://synapse.chat
SYNAPSE_REGISTRATION_SHARED_SECRET=CHANGE_ME_IN_PRODUCTION

# ─── coturn TURN Server ───
TURN_SECRET=synapsechat_dev_turn_secret