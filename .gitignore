.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Node
node_modules/
dist/
build/

# Docker
docker-compose.override.yml